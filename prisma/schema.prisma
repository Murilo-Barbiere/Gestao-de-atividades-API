generator client {                                                                                                        
  provider = "prisma-client"                                                                                           
  output   = "../generated/prisma" 
  moduleFormat = "cjs"                                                                                       
}

datasource db {
  provider = "postgresql"
}

enum PrioridadeTarefa {
  URGENTE
  ALTA
  MEDIA
  BAIXA
}

model user {
  id Int @id @default(autoincrement())
  name  String
  email String @unique
  senha String

  listas_tarefas lista_tarefa[]

  tags_criador tags[]
}

model tarefa {
  id Int @id @default(autoincrement())
  titulo String
  realizada Boolean
  prioridade PrioridadeTarefa
  data_vencimento DateTime @db.Date

  lista_id Int
  lista lista_tarefa @relation(fields: [lista_id], references: [id], onDelete: Cascade)

  tags tags[]
} 

model lista_tarefa {
  id Int @id @default(autoincrement())
  nome String

  user_id Int 
  user user @relation(fields: [user_id], references: [id], onDelete: Cascade)

  tarefas tarefa[]
}

model tags{
  id Int @id @default(autoincrement())
  name String @unique

  user_id Int 
  user user @relation(fields: [user_id], references: [id], onDelete: Cascade)

  tarefas tarefa[]
}