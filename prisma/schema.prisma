generator client {                                                                                                        
  provider = "prisma-client"                                                                                           
  output   = "../generated/prisma" 
  moduleFormat = "cjs"                                                                                       
}

datasource db {
  provider = "postgresql"
}

enum PrioridadeAtividade {
  URGENTE
  ALTA
  MEDIA
  BAIXA
}

model user {
  id Int @id @default(autoincrement())
  name  String
  email String @unique
  senha String

  projetos projeto[]

  tags_criador tags[]
}

model atividade {
  id Int @id @default(autoincrement())
  titulo String
  realizada Boolean
  prioridade PrioridadeAtividade
  data_vencimento DateTime @db.Date
  texto String? @db.Text

  projeto_id Int
  projeto projeto @relation(fields: [projeto_id], references: [id], onDelete: Cascade)

  paiId Int?
  pai atividade? @relation("HierarquiaAtividade", fields: [paiId], references: [id])

  subtarefas atividade[] @relation("HierarquiaAtividade")

  tags tags[]
} 

model projeto {
  id Int @id @default(autoincrement())
  nome String

  user user[]

  atividades atividade[]
}

model tags{
  id Int @id @default(autoincrement())
  name String @unique

  user_id Int 
  user user @relation(fields: [user_id], references: [id], onDelete: Cascade)

  atividades atividade[]
}